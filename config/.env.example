# Base RPC (Alchemy recommended, public fallback: https://mainnet.base.org)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Wallet (for on-chain execution — NOT needed for data-only mode)
PRIVATE_KEY=

# Uniswap Trading API key (for swap execution)
UNISWAP_API_KEY=

# Anthropic API key (for AI swap reasoning — optional, rule-based fallback)
ANTHROPIC_API_KEY=

# Optional: Blocknative API key for gas predictions
BLOCKNATIVE_API_KEY=
